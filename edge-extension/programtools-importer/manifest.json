{
  "manifest_version": 3,
  "name": "ProgramTools Multi-Site Importer",
  "version": "0.2.1",
  "description": "从 MNA、AtCoder、核桃 OJ、NFLSOI、YbtOJ 页面导入题目到 SolveData。",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://mna.wang/*",
    "https://atcoder.jp/*",
    "https://htoj.com.cn/*",
    "https://nflsoi.cc/*",
    "http://nflsoi.cc/*",
    "http://nflsoi.cc:10611/*",
    "http://nflsoi.cc:20035/*",
    "http://noip.ybtoj.com.cn/*",
    "https://noip.ybtoj.com.cn/*",
    "https://ai.acjudge.com/*",
    "https://acjudge.com/*",
    "https://www.acjudge.com/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "导入题目到 SolveData"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ai.acjudge.com/solvedata*",
        "https://acjudge.com/solvedata*",
        "https://www.acjudge.com/solvedata*",
        "http://localhost:5173/solvedata*",
        "http://127.0.0.1:5173/solvedata*"
      ],
      "js": ["solvedata-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}