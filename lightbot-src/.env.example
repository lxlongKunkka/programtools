# ── 管理员密码 ──────────────────────────────────────────────────────────────
# 设置管理员密码（明文密码的 SHA-256 十六进制摘要）。
# 生成方式（浏览器控制台运行）：
#   const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode('你的密码'))
#   console.log(Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join(''))
# 若不设置，管理员登录功能将被禁用。
VITE_ADMIN_PASSWORD_HASH=your-sha256-hash-here

# ── 关卡投稿邮件通知 ─────────────────────────────────────────────────────────
# 普通用户在编辑器中点击「📤 投稿」时，会打开邮件客户端并自动填写收件人/标题/正文。
# 填写管理员邮箱后，编辑器中会显示「📤 投稿」按钮；留空则不显示。
VITE_ADMIN_EMAIL=admin@example.com

# ── Supabase 社区关卡功能 ────────────────────────────────────────────────────
# 1. 访问 https://supabase.com 创建免费项目
# 2. 在 Project Settings → API 中找到以下两个值
# 3. 复制此文件为 .env.local 并填入真实值
# 4. Vercel 部署时在 Environment Variables 中同样配置这两个变量

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
